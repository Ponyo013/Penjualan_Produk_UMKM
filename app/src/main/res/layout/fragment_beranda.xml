<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".client.ui.beranda.BerandaFragment">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Header -->
            <include
                layout="@layout/fragment_header"
                android:id="@+id/header_layout" />

            <!-- Search Bar -->
            <EditText
                android:id="@+id/etSearch"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="Cari produk..."
                android:padding="12dp"
                android:background="@drawable/bg_search"
                android:drawableStart="@android:drawable/ic_menu_search"
                android:drawablePadding="8dp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="12dp"
                android:inputType="text" />

            <!-- Banner -->
            <ImageView
                android:id="@+id/imgBanner"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:adjustViewBounds="true"
                android:scaleType="centerCrop"
                android:src="@drawable/banner_sepeda"
                android:contentDescription="Banner Sepeda" />

            <!-- Section: Kategori -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kategori"
                android:textStyle="bold"
                android:textSize="18sp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="3"
                android:gravity="center"
                android:layout_marginBottom="16dp">

                <ImageView
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_weight="1"
                    android:src="@drawable/kategori_sepeda"
                    android:contentDescription="Sepeda"
                    android:background="@drawable/rounded_square"
                    android:scaleType="centerInside"
                    android:layout_margin="4dp"
                    android:padding="12dp" />

                <ImageView
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_weight="1"
                    android:src="@drawable/kategori_parts"
                    android:contentDescription="Parts"
                    android:background="@drawable/rounded_square"
                    android:scaleType="centerInside"
                    android:layout_margin="4dp"
                    android:padding="12dp" />

                <ImageView
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_weight="1"
                    android:src="@drawable/kategori_accessories"
                    android:contentDescription="Aksesoris"
                    android:background="@drawable/rounded_square"
                    android:scaleType="centerInside"
                    android:layout_margin="4dp"
                    android:padding="12dp" />
            </LinearLayout>


            <!-- Section: Produk Populer -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Produk Populer"
                android:textStyle="bold"
                android:textSize="18sp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="12dp" />

            <GridLayout
                android:id="@+id/gridProdukPopuler"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:alignmentMode="alignMargins"
                android:rowOrderPreserved="false">

                <ImageView
                    android:layout_width="0dp"
                    android:layout_height="160dp"
                    android:layout_columnWeight="1"
                    android:src="@drawable/produk_bmx"
                    android:scaleType="centerCrop"
                    android:layout_margin="8dp"
                    android:contentDescription="Produk 1" />

                <ImageView
                    android:layout_width="0dp"
                    android:layout_height="160dp"
                    android:layout_columnWeight="1"
                    android:src="@drawable/produk_mini"
                    android:scaleType="centerCrop"
                    android:layout_margin="8dp"
                    android:contentDescription="Produk 2" />

                <ImageView
                    android:layout_width="0dp"
                    android:layout_height="160dp"
                    android:layout_columnWeight="1"
                    android:src="@drawable/produk_banmaxis"
                    android:scaleType="centerCrop"
                    android:layout_margin="8dp"
                    android:contentDescription="Produk 3" />

                <ImageView
                    android:layout_width="0dp"
                    android:layout_height="160dp"
                    android:layout_columnWeight="1"
                    android:src="@drawable/produk_helmgiro"
                    android:scaleType="centerCrop"
                    android:layout_margin="8dp"
                    android:contentDescription="Produk 4" />
            </GridLayout>
        </LinearLayout>
    </ScrollView>

</FrameLayout>
